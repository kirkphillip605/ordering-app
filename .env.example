# ==============================================================================
# ChefList - Environment Configuration Template
# Copy this file to '.env' and adjust the values for your environment.
# ==============================================================================

# --- SERVER CONFIGURATION ---
PORT=3001
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# --- DATABASE CONFIGURATION ---
# For PostgreSQL (Docker / Production):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cheflist

# For SQLite (Fallback / Local Development):
# If DATABASE_URL is not provided, the app will automatically fall back to SQLite.
SQLITE_DB_PATH=./chef_list.db

# --- FRONTEND CONFIGURATION (VITE) ---
# The frontend dev server proxies '/api' to the backend automatically.
# If you need to change the backend URL for production builds:
VITE_API_URL=http://localhost:3001
